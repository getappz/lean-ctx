{
    "service": "payment-gateway",
    "environment": "production",
    "feature_flags": {
        "enable_idempotency_keys": true,
        "enable_3ds": true,
        "enable_partial_refunds": false,
        "enable_dark_launch": false
    },
    "processors": [
        {
            "name": "acme-cards",
            "weight": 70,
            "regions": ["eu-west-1", "eu-central-1"],
            "supported_currencies": ["EUR", "CHF", "GBP"]
        },
        {
            "name": "globex-cards",
            "weight": 30,
            "regions": ["us-east-1", "us-west-2"],
            "supported_currencies": ["USD", "CAD", "MXN"]
        }
    ],
    "timeouts_ms": {
        "connect": 1000,
        "read": 5000,
        "total": 8000
    },
    "webhooks": {
        "charge_succeeded": "https://example.invalid/hooks/charge_succeeded",
        "charge_failed": "https://example.invalid/hooks/charge_failed",
        "refund_succeeded": "https://example.invalid/hooks/refund_succeeded"
    }
}
